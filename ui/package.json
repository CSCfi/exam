{
  "name": "exam",
  "version": "5.3.0",
  "description": "EXAM – electronic exam software for higher education",
  "repository": {
    "type": "git",
    "url": " https://github.com/CSCfi/exam.git"
  },
  "license": "EUPL-1.1",
  "scripts": {
    "ng": "ng",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "start": "ng serve --open --proxy-config src/proxy.conf.js --host 0.0.0.0",
    "test": "ng test --watch",
    "test:ci": "ng test --watch=false --browsers ChromeHeadless",
    "test:coverage": "ng test --watch=true --code-coverage=true",
    "test:coverage:ci": "ng test --watch=false --code-coverage=true --browsers ChromeHeadless",
    "build:dev": "ng build --progress --output-path ../public",
    "build:prod": "ng build --progress --prod --output-path ../public"
  },
  "dependencies": {
    "@angular/animations": "^9.0.0",
    "@angular/cdk": "^9.0.0",
    "@angular/common": "^9.0.0",
    "@angular/compiler": "^9.0.0",
    "@angular/core": "^9.0.0",
    "@angular/forms": "^9.0.0",
    "@angular/localize": "^9.0.0",
    "@angular/platform-browser": "^9.0.0",
    "@angular/platform-browser-dynamic": "^9.0.0",
    "@angular/router": "^9.0.0",
    "@ng-bootstrap/ng-bootstrap": "^6.0.0",
    "@ngx-translate/core": "^12.0.0",
    "@ngx-translate/http-loader": "^5.0.0",
    "@uirouter/angular": "^7.0.0",
    "@uirouter/core": "^6.0.5",
    "@uirouter/rx": "^0.6.0",
    "@uirouter/visualizer": "7.2.1",
    "angular-calendar": "^0.28.22",
    "base64-js": "^1.3.1",
    "bootstrap": "^4.4.1",
    "bootstrap-icons": "^1.3.0",
    "chart.js": "^2.9.4",
    "core-js": "^3.6.5",
    "date-fns": "^2.16.1",
    "file-saver": "^2.0.5",
    "lodash": "^4.17.19",
    "moment": "^2.22.2",
    "moment-timezone": "0.5.31",
    "ngx-order-pipe": "^2.0.2",
    "ngx-webstorage-service": "^4.1.0",
    "popper.js": "^1.16.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^6.6.3",
    "toastr": "^2.1.4",
    "zone.js": "^0.10.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^0.901.0",
    "@angular/cli": "^9.0.0",
    "@angular/compiler-cli": "^9.1.0",
    "@angular/language-service": "^9.0.0",
    "@types/base64-js": "^1.2.5",
    "@types/chart.js": "^2.9.29",
    "@types/ckeditor": "^0.0.46",
    "@types/file-saver": "1.3.0",
    "@types/jasmine": "~3.3.13",
    "@types/jasminewd2": "~2.0.6",
    "@types/lodash": "^4.14.149",
    "@types/mathjax": "^0.0.32",
    "@types/node": "^12.6.8",
    "@types/toastr": "^2.1.37",
    "@typescript-eslint/eslint-plugin": "^2.28.0",
    "@typescript-eslint/parser": "^2.28.0",
    "codelyzer": "~5.1.0",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.10.1",
    "eslint-plugin-prettier": "^3.3.1",
    "husky": "^3.1.0",
    "jasmine-core": "~3.4.0",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "~5.0.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~2.1.0",
    "karma-jasmine": "~3.0.1",
    "karma-jasmine-html-reporter": "^1.4.2",
    "lint-staged": "^9.5.0",
    "prettier": "^1.19.1",
    "prettier-plugin-java": "^0.8.2",
    "protractor": "~7.0.0",
    "ts-node": "~8.3.0",
    "tslint": "~6.1.0",
    "typescript": "~3.8.3"
  },
  "engines": {
    "node": ">= 10",
    "npm": ">= 6"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,html}": [
      "prettier --write",
      "git add"
    ],
    "../backend/**/*.java": [
      "prettier --write --print-width=120 --tab-width=4",
      "git add"
    ],
    "../../test/**/*.java": [
      "prettier --write --print-width=120 --tab-width=4",
      "git add"
    ],
    "*.{ts,js}": [
      "eslint --fix",
      "git add"
    ]
  }
}
