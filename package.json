{
  "name": "exam",
  "version": "6.4.0",
  "description": "EXAM – electronic exam software for higher education",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": " https://github.com/CSCfi/exam.git"
  },
  "license": "EUPL-1.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200",
    "build": "ng build --output-path ./public",
    "postinstall": "lefthook install",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint --fix",
    "format": "prettier --write \"ui/src/app/**/*.{ts,html}\" --print-width=120 --tab-width=4; exit 0",
    "check-format": "prettier --check \"ui/src/app/**/*.{ts,html}\" --print-width=120 --tab-width=4",
    "check-lint": "ng lint",
    "analyze": "ng build --configuration production && node scripts/internal/analyze-chunks.js"
  },
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/localize": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@ckeditor/ckeditor5-angular": "^11.1.0",
    "@fullcalendar/angular": "^6.1.20",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/luxon3": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@ng-bootstrap/ng-bootstrap": "20.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "ckeditor5": "^47.6.1",
    "luxon": "^3.7.2",
    "mathlive": "^0.107.1",
    "ngx-toastr": "^19.1.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/luxon": "^3.7.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "jsdom": "^27.4.0",
    "lefthook": "^1.13.6",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
